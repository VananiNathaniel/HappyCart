# Exclude generated files from language statistics
dist/* linguist-generated=true

# Exclude vendor libraries
vendor/* linguist-vendored=true

# Include vendor files in statistics
vendor/* linguist-vendored=false

# Force a language
*.inc linguist-language=PHP
*.tpl linguist-language=HTML

# Force GitHub to count a specific folder
my-special-folder/* linguist-vendored=false

# Force GitHub to detect a specific language for an extension
*.js linguist-language=JavaScript